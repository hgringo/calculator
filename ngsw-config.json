{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.csr.html",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "!/assets/version.json",
          "/assets/**",
          "node_modules/primeicons/**",
          "/*.png",
          "/*.jpg",
          "/*.svg",
          "/*.webp",
          "/*.ico"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "version-api",
      "urls": [
        "/assets/version.json"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 1,
        "maxAge": "0u",
        "timeout": "1s"
      }
    }
  ]
}